PORT=3001
NODE_ENV=development
LOG_LEVEL=info
ALLOWED_ORIGIN=http://localhost:5173

# Development runs without local infrastructure by default (in-memory repo).
# The middleware ALWAYS uses the real GroundX / LLM clients — there is no mock
# mode. Supply real keys below to exercise the live data path locally.
# Set APP_REPOSITORY_MODE=mysql and fill these values for real MySQL.
APP_REPOSITORY_MODE=memory
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_DATABASE=groundx_app
# MYSQL_USER=groundx_app
# MYSQL_PASSWORD=change-me

SESSION_SECRET=replace-with-a-long-random-secret
GROUNDX_BASE_URL=https://api.groundx.ai/api/v1
# Required — the real GroundX Partner API key the middleware authenticates with.
GROUNDX_PARTNER_API_KEY=
GROUNDX_ANON_API_KEY=
# Required for the onboarding sample flow. The chat router's
# `deriveRagContentScope` falls back to this when the active entity
# has no scope refs of its own. Without it, scope is "unknown" and
# every grounded reply degenerates to "I don't have any snippets."
# Use 28454 for the canonical dev/staging samples bucket; override
# for production deployments with their own samples bucket.
GROUNDX_SAMPLES_BUCKET_ID=28454

LLM_BASE_URL=https://api.openai.com/v1
LLM_SERVICE=
# Required — the real LLM provider API key the middleware authenticates with.
LLM_API_KEY=
LLM_AUTH_HEADER_NAME=Authorization
LLM_AUTH_SCHEME=Bearer
LLM_MODEL_ID=

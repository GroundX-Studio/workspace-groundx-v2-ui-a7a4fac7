# The frontend calls same-origin /api. Deployment routes /api/* to the middleware scaffold.
# GroundX, Partner API, and LLM secrets belong in middleware/.env.local, never here.
VITE_SDK_DEFAULT_PAGE_SIZE=20

# Calendly link the F6a "Book a call with an engineer" CTA loads inline.
# Leaving this unset keeps the CTA visible but renders an empty
# placeholder + a console warning. Copy to ignored app/.env locally,
# or pass as a Docker build arg in deploys.
VITE_CALENDLY_URL=https://calendly.com/d/d3wn-ryv-rmr/30-minutes-with-a-groundx-engineer
